---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config';
import { getFeaturedProjects } from '../lib/projects';

const featured = await getFeaturedProjects(3);
---

<BaseLayout
  title={`${siteConfig.siteName} — Software Engineer`}
  description={siteConfig.description}
>
  <section class="hero">
    <h1>{siteConfig.author}</h1>
    <p class="hero__role">Software Engineer</p>
    <p class="hero__intro">
      I build developer tools, web services, and systems that prefer small, sharp
      pieces over sprawling frameworks.
    </p>
    <div class="hero__ctas">
      <a class="cta" href="/projects">View projects</a>
      <a class="cta cta--ghost" href="/contact">Get in touch</a>
    </div>
  </section>

  {featured.length > 0 && (
    <section class="featured" aria-labelledby="featured-heading">
      <h2 id="featured-heading">Featured projects</h2>
      <ul class="featured__list">
        {featured.map((entry) => (
          <li>
            <a href={`/projects/${entry.slug}/`} class="featured__item">
              <span class="featured__title">{entry.data.title}</span>
              <span class="featured__desc">{entry.data.description}</span>
            </a>
          </li>
        ))}
      </ul>
      <p class="featured__more">
        <a href="/projects">All projects &rarr;</a>
      </p>
    </section>
  )}
</BaseLayout>

<style>
  .hero {
    padding: 40px 0 24px;
    border-bottom: 1px solid #222;
  }

  .hero h1 {
    font-size: 2.2rem;
    color: #cfcfcf;
    margin-bottom: 6px;
  }

  .hero__role {
    color: rgba(0, 255, 26, 0.8);
    margin-bottom: 14px;
    font-size: 1rem;
  }

  .hero__intro {
    max-width: 640px;
    margin-bottom: 22px;
  }

  .hero__ctas {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  .cta {
    display: inline-block;
    padding: 10px 18px;
    border: 1px solid rgba(0, 255, 26, 0.5);
    color: rgba(0, 255, 26, 0.9);
  }

  .cta:hover,
  .cta:focus-visible {
    background-color: rgba(0, 255, 26, 0.1);
    color: rgba(0, 255, 26, 1);
  }

  .cta--ghost {
    border-color: #333;
    color: #989898;
  }

  .cta--ghost:hover,
  .cta--ghost:focus-visible {
    border-color: rgba(0, 255, 26, 0.5);
    color: rgba(0, 255, 26, 0.9);
  }

  .featured {
    padding: 28px 0;
  }

  .featured h2 {
    font-size: 1.4rem;
    color: #cfcfcf;
    margin-bottom: 14px;
  }

  .featured__list {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 10px;
  }

  .featured__item {
    display: flex;
    flex-direction: column;
    padding: 14px;
    background-color: #1a1a1a;
    border: 1px solid #222;
    color: #989898;
  }

  .featured__item:hover,
  .featured__item:focus-visible {
    border-color: rgba(0, 255, 26, 0.5);
    color: #cfcfcf;
  }

  .featured__title {
    font-size: 1.05rem;
    color: rgba(0, 255, 26, 0.9);
    margin-bottom: 4px;
  }

  .featured__desc {
    font-size: 0.9rem;
  }

  .featured__more {
    margin-top: 16px;
  }
</style>
