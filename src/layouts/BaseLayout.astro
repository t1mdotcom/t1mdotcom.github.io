---
import '../styles/global.css';
import monaspace400 from '@fontsource/monaspace-neon/files/monaspace-neon-latin-400-normal.woff2';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { siteConfig } from '../config';

export interface Props {
  title: string;
  description?: string;
  ogType?: 'website' | 'article';
  ogImage?: string;
}

const { title, description, ogType = 'website', ogImage } = Astro.props;
const resolvedDescription = description ?? siteConfig.description;
const canonicalUrl = new URL(Astro.url.pathname, siteConfig.siteUrl).toString();
const resolvedOgImage = new URL(ogImage ?? '/assets/img/og.png', siteConfig.siteUrl).toString();

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: siteConfig.author,
  url: siteConfig.siteUrl,
  email: `mailto:${siteConfig.email}`,
  jobTitle: 'AI-Augmented Software Engineer',
  sameAs: siteConfig.socialLinks
    .filter((link) => link.platform !== 'GPG')
    .map((link) => link.url),
};
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/assets/img/favicon.ico" />
    <link rel="preload" as="font" type="font/woff2" href={monaspace400} crossorigin />
    <title>{title}</title>
    <meta name="description" content={resolvedDescription} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={resolvedDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteConfig.siteName} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${siteConfig.author} — AI-Augmented Software Engineer`} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={resolvedDescription} />
    <meta name="twitter:image" content={resolvedOgImage} />

    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <div class="wrapper">
      <Header />
      <main id="main" class="site-main">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>

<style is:global>
  body {
    background-color: var(--bg);
  }

  .wrapper {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    position: relative;
    z-index: 1;
  }

  .site-main {
    flex: 1;
    max-width: 1100px;
    width: 100%;
    margin: 0 auto;
    padding: 42px 20px;
    color: var(--text);
  }

  .skip-link {
    position: absolute;
    left: -9999px;
    top: 0;
    background: var(--bg-deep);
    color: var(--green);
    padding: 10px 14px;
    z-index: 1000;
    border: 1px solid var(--line-strong);
  }

  .skip-link:focus-visible {
    left: 10px;
    top: 10px;
    outline: 2px solid var(--cyan);
    outline-offset: 2px;
  }

  html,
  body {
    overflow-x: hidden;
    max-width: 100%;
  }
</style>
