---
import { siteConfig } from '../config';
import { Briefcase, Mail, Terminal, UserRound } from '@lucide/astro';

const navItems = [
  { label: 'About', href: '#about', icon: UserRound },
  { label: 'Work', href: '#work', icon: Briefcase },
  { label: 'Contact', href: '#contact', icon: Mail },
];
---

<header class="site-header">
  <div class="site-header__inner">
    <a class="site-header__brand" href="#top">
      <span class="site-header__prompt"><Terminal class="icon" size={16} aria-hidden="true" /> ~/</span>
      <h1>{siteConfig.siteName}</h1>
    </a>
    <nav aria-label="Primary">
      <ul class="site-header__nav">
        {navItems.map(({ label, href, icon: Icon }) => (
          <li>
            <a href={href} class="site-header__link" data-section={href.slice(1)}>
              <Icon class="icon" size={16} aria-hidden="true" />
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<script>
  // Scroll-Spy: markiert den Nav-Link des aktuell sichtbaren Abschnitts.
  const links = Array.from(
    document.querySelectorAll<HTMLAnchorElement>('.site-header__link'),
  );
  const byId = new Map(links.map((link) => [link.dataset.section, link]));
  const sections = Array.from(byId.keys())
    .map((id) => (id ? document.getElementById(id) : null))
    .filter((el): el is HTMLElement => el !== null);

  const setActive = (id: string | undefined) => {
    links.forEach((link) => {
      const active = link.dataset.section === id;
      link.classList.toggle('is-active', active);
      if (active) {
        link.setAttribute('aria-current', 'true');
      } else {
        link.removeAttribute('aria-current');
      }
    });
  };

  const observer = new IntersectionObserver(
    (entries) => {
      const visible = entries
        .filter((entry) => entry.isIntersecting)
        .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
      if (visible) setActive(visible.target.id);
    },
    { rootMargin: '-45% 0px -50% 0px', threshold: 0 },
  );

  sections.forEach((section) => observer.observe(section));
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background-color: rgba(5, 7, 6, 0.92);
    backdrop-filter: blur(6px);
    padding: 14px 20px;
    border-bottom: 1px solid var(--line);
  }

  .site-header__inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    max-width: 1100px;
    margin: 0 auto;
  }

  .site-header__brand {
    text-decoration: none;
    color: var(--text-strong);
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
  }

  .site-header__brand h1 {
    font-size: 1.4rem;
    font-weight: 400;
    margin: 0;
  }

  .site-header__prompt {
    color: var(--green);
    font-size: 0.95rem;
    display: inline-flex;
    align-items: center;
    gap: 5px;
  }

  .site-header__nav {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    margin: 0;
    padding: 0;
  }

  .site-header__link {
    color: var(--text);
    font-size: 1rem;
    border-bottom: 1px solid transparent;
    padding-bottom: 2px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .site-header__link:hover,
  .site-header__link:focus-visible {
    color: var(--cyan);
  }

  .site-header__link.is-active {
    color: var(--green);
    border-bottom-color: var(--magenta);
    text-decoration: none;
  }

  @media (max-width: 640px) {
    .site-header__inner {
      flex-direction: column;
      align-items: flex-start;
    }

    .site-header__nav {
      width: 100%;
      gap: 14px;
    }
  }
</style>
