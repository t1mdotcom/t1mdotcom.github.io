---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="404 — Page not found · Tim Heinemann"
  description="The page you are looking for does not exist. Head back to the home page."
>
  <section class="not-found">
    <h1>404 &mdash; Page not found</h1>
    <p>
      The page you tried to reach does not exist on this site.
    </p>
    <p>
      <a href="/">&larr; Back to home</a>
    </p>
  </section>
</BaseLayout>

<style>
  .not-found {
    padding: 40px 0;
  }

  .not-found h1 {
    font-size: 1.8rem;
    margin-bottom: 16px;
    color: #cfcfcf;
  }

  .not-found p {
    margin-bottom: 12px;
  }
</style>
