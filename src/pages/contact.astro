---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config';
import {
  ContactRound,
  ExternalLink,
  GitBranch,
  KeyRound,
  Mail,
  Network,
  Send,
} from '@lucide/astro';

const gpgLink = siteConfig.socialLinks.find((link) => link.platform === 'GPG');
const linkedInLink = siteConfig.socialLinks.find((link) => link.platform === 'LinkedIn');
const profileLinks = siteConfig.socialLinks.filter((link) =>
  ['GitHub', 'LinkedIn', 'Xing'].includes(link.platform),
);

const getProfileIcon = (platform: string) => {
  if (platform === 'GitHub') return GitBranch;
  if (platform === 'LinkedIn') return ContactRound;
  return Network;
};
---

<BaseLayout
  title={`Contact — ${siteConfig.siteName}`}
  description={`Reach ${siteConfig.author} via e-mail, GPG, or social profiles.`}
>
  <section id="contact">
    <header class="contact__header">
      <p class="contact__eyebrow">/contact</p>
      <h1>Contact</h1>
      <p>I am happily employed, but always open to thoughtful professional contact.</p>
    </header>

    {linkedInLink && (
      <div class="contact__section contact__primary">
        <h2>
          <Send class="icon" size={19} aria-hidden="true" />
          Preferred
        </h2>
        <p class="contact__primary-copy">
          The cleanest route for professional exchange, recruiter contact, and relevant opportunities.
        </p>
        <p>
          <a class="primary-link" href={linkedInLink.url} target="_blank" rel="noopener">
            <ContactRound class="icon" size={18} aria-hidden="true" />
            Connect on LinkedIn
          </a>
        </p>
      </div>
    )}

    <div class="contact__section">
      <h2>
        <Mail class="icon" size={19} aria-hidden="true" />
        E-mail
      </h2>
      <ul class="contact-info">
        <li>
          <a href={`mailto:${siteConfig.email}`}>
            <Mail class="icon" size={16} aria-hidden="true" />
            {siteConfig.email}
          </a>
        </li>
      </ul>
      {gpgLink && (
        <p>
          Public key:
          <a class="link" href={gpgLink.url} target="_blank" rel="noopener">
            <KeyRound class="icon" size={15} aria-hidden="true" />
            GPG on keyserver.ubuntu.com
            <ExternalLink class="icon" size={14} aria-hidden="true" />
          </a>
        </p>
      )}
    </div>

    <div class="contact__section">
      <h2>
        <Network class="icon" size={19} aria-hidden="true" />
        Profiles
      </h2>
      <ul class="social-links">
        {profileLinks.map((link) => {
          const Icon = getProfileIcon(link.platform);
          return (
          <li>
            <a href={link.url} target="_blank" rel="noopener">
              <Icon class="icon" size={16} aria-hidden="true" />
              {link.platform}
              <ExternalLink class="icon" size={13} aria-hidden="true" />
            </a>
          </li>
          );
        })}
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .contact__header {
    padding: 20px;
    border: 1px solid var(--line);
    background:
      linear-gradient(90deg, rgba(255, 79, 216, 0.08), transparent 50%),
      var(--panel);
    margin-bottom: 24px;
  }

  .contact__eyebrow {
    color: var(--magenta);
    font-size: 0.85rem;
    margin-bottom: 4px;
  }

  .contact__header h1 {
    font-size: 2rem;
    color: var(--text-strong);
    margin-bottom: 4px;
  }

  .contact__section {
    margin-bottom: 28px;
  }

  .contact__primary {
    padding: 18px;
    background-color: var(--panel);
    border: 1px solid var(--line-strong);
  }

  .contact__primary-copy {
    max-width: 620px;
    margin-bottom: 14px;
  }

  .contact__section h2 {
    font-size: 1.2rem;
    color: var(--text-strong);
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .contact-info,
  .social-links {
    list-style: none;
    padding: 0;
  }

  .contact-info li,
  .social-links li {
    margin-bottom: 8px;
  }

  .social-links {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
  }

  .social-links li {
    margin-bottom: 0;
  }

  .link {
    margin-left: 4px;
    display: inline-flex;
    align-items: center;
    gap: 5px;
  }

  .contact-info a,
  .social-links a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .primary-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
    border: 1px solid var(--line-strong);
    background-color: var(--green);
    color: var(--bg-deep);
  }

  .primary-link:hover,
  .primary-link:focus-visible {
    background-color: var(--cyan);
    border-color: var(--cyan);
    color: var(--bg-deep);
  }
</style>
