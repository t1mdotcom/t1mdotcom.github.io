---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config';
import { getFeaturedProjects } from '../lib/projects';
import {
  ArrowRight,
  Bot,
  Code,
  ContactRound,
  Container,
  GitBranch,
  ServerCog,
  Terminal,
} from '@lucide/astro';

const featured = await getFeaturedProjects(3);

const signals = [
  { label: 'Angular + TypeScript interfaces', icon: Code },
  { label: 'Java/Spring services with Gradle', icon: ServerCog },
  { label: 'GitLab/GitHub CI/CD and Docker', icon: Container },
  { label: 'Claude Code, Codex, Junie, CLI workflows', icon: Bot },
];
---

<BaseLayout
  title={`${siteConfig.siteName} — AI-Augmented Software Engineer`}
  description={siteConfig.description}
>
  <section class="hero">
    <div class="terminal-panel" aria-label="Profile terminal">
      <div class="terminal-panel__bar">
        <span></span>
        <span></span>
        <span></span>
        <p><Terminal class="icon" size={14} aria-hidden="true" /> profile.sh</p>
      </div>
      <div class="terminal-panel__body">
        <p class="terminal-line"><span>$</span> whoami</p>
        <h1>{siteConfig.author}</h1>
        <p class="hero__role">AI-Augmented Software Engineer</p>
        <p class="terminal-line"><span>$</span> cat daily-focus.txt</p>
        <p class="hero__intro">
          Full-stack web development, DevOps tasks, and Linux server administration,
          sharpened by practical AI workflows on the command line.
        </p>
        <ul class="hero__signals" aria-label="Engineering focus">
          {signals.map(({ label, icon: Icon }) => (
            <li>
              <Icon class="icon" size={17} aria-hidden="true" />
              {label}
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="hero__ctas" aria-label="Primary actions">
      <a class="cta" href="https://www.linkedin.com/in/tim-heinemann-524764190/" target="_blank" rel="noopener">
        <ContactRound class="icon" size={18} aria-hidden="true" />
        Connect on LinkedIn
      </a>
      <a class="cta cta--ghost" href="/projects">
        <GitBranch class="icon" size={18} aria-hidden="true" />
        View work patterns
      </a>
    </div>
  </section>

  {featured.length > 0 && (
    <section class="featured" aria-labelledby="featured-heading">
      <h2 id="featured-heading">Daily engineering focus</h2>
      <ul class="featured__list">
        {featured.map((entry) => (
          <li>
            <a href={`/projects/${entry.slug}/`} class="featured__item">
              <span class="featured__title">{entry.data.title}</span>
              <span class="featured__desc">{entry.data.description}</span>
              <span class="featured__read">
                Open case file
                <ArrowRight class="icon" size={15} aria-hidden="true" />
              </span>
            </a>
          </li>
        ))}
      </ul>
      <p class="featured__more">
        <a href="/projects">All work patterns &rarr;</a>
      </p>
    </section>
  )}
</BaseLayout>

<style>
  .hero {
    padding: 22px 0 34px;
    border-bottom: 1px solid var(--line);
  }

  .terminal-panel {
    background:
      linear-gradient(135deg, rgba(121, 255, 180, 0.08), transparent 34%),
      var(--panel);
    border: 1px solid var(--line-strong);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.04),
      0 18px 50px rgba(0, 0, 0, 0.35);
  }

  .terminal-panel__bar {
    min-height: 40px;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 0 14px;
    background-color: rgba(5, 7, 6, 0.86);
    border-bottom: 1px solid var(--line);
  }

  .terminal-panel__bar span {
    width: 9px;
    height: 9px;
    border-radius: 999px;
    border: 1px solid var(--line-strong);
  }

  .terminal-panel__bar span:nth-child(1) {
    background-color: var(--magenta);
  }

  .terminal-panel__bar span:nth-child(2) {
    background-color: var(--cyan);
  }

  .terminal-panel__bar span:nth-child(3) {
    background-color: var(--green);
  }

  .terminal-panel__bar p {
    margin-left: 8px;
    color: var(--muted);
    font-size: 0.82rem;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .terminal-panel__body {
    padding: 28px;
  }

  .terminal-line {
    color: var(--muted);
    font-size: 0.92rem;
    margin-bottom: 6px;
  }

  .terminal-line span {
    color: var(--green);
  }

  .hero h1 {
    font-size: 2.4rem;
    color: var(--text-strong);
    margin-bottom: 4px;
  }

  .hero__role {
    color: var(--green);
    margin-bottom: 22px;
    font-size: 1rem;
  }

  .hero__intro {
    max-width: 760px;
    margin-bottom: 18px;
    color: var(--text-strong);
  }

  .hero__signals {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 8px;
    padding: 0;
    margin-top: 18px;
  }

  .hero__signals li {
    background-color: rgba(5, 7, 6, 0.5);
    border: 1px solid var(--line);
    color: var(--text);
    padding: 9px 11px;
    font-size: 0.9rem;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .hero__signals :global(.icon) {
    color: var(--magenta);
  }

  .hero__ctas {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin-top: 22px;
  }

  .cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 11px 18px;
    border: 1px solid var(--line-strong);
    color: var(--bg-deep);
    background-color: var(--green);
    box-shadow: 0 0 22px rgba(121, 255, 180, 0.16);
  }

  .cta:hover,
  .cta:focus-visible {
    background-color: var(--cyan);
    border-color: var(--cyan);
    color: var(--bg-deep);
  }

  .cta--ghost {
    background-color: transparent;
    border-color: var(--line);
    color: var(--text);
    box-shadow: none;
  }

  .cta--ghost:hover,
  .cta--ghost:focus-visible {
    background-color: rgba(97, 217, 255, 0.08);
    border-color: var(--cyan);
    color: var(--cyan);
  }

  .featured {
    padding: 34px 0 0;
  }

  .featured h2 {
    font-size: 1.4rem;
    color: var(--text-strong);
    margin-bottom: 14px;
  }

  .featured__list {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }

  .featured__item {
    display: flex;
    flex-direction: column;
    min-height: 100%;
    padding: 16px;
    background-color: var(--panel);
    border: 1px solid var(--line);
    color: var(--text);
  }

  .featured__item:hover,
  .featured__item:focus-visible {
    border-color: var(--cyan);
    color: var(--text-strong);
    background-color: var(--panel-strong);
  }

  .featured__title {
    font-size: 1.05rem;
    color: var(--green);
    margin-bottom: 4px;
  }

  .featured__desc {
    font-size: 0.9rem;
  }

  .featured__read {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 14px;
    color: var(--cyan);
    font-size: 0.85rem;
  }

  .featured__more {
    margin-top: 16px;
  }

  @media (max-width: 760px) {
    .terminal-panel__body {
      padding: 20px;
    }

    .hero h1 {
      font-size: 2rem;
    }

    .hero__signals,
    .featured__list {
      grid-template-columns: 1fr;
    }
  }
</style>
