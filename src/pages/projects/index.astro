---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteConfig } from '../../config';
import { getPublishedProjects } from '../../lib/projects';
import { Image } from 'astro:assets';
import { ArrowRight, Calendar, ExternalLink, FileTerminal, Tags } from '@lucide/astro';

const projects = await getPublishedProjects();

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' });
---

<BaseLayout
  title={`Work Patterns — ${siteConfig.siteName}`}
  description={`Selected work patterns by ${siteConfig.author} — full-stack development, DevOps, Linux operations, and AI-assisted engineering.`}
>
  <section>
    <header class="projects__header">
      <p class="eyebrow">/work</p>
      <h1>Work Patterns</h1>
      <p>Selected areas from my daily engineering work.</p>
    </header>

    <ul class="projects__list">
      {projects.map((entry) => (
        <li class="project-card">
          {entry.data.cover && (
            <div class="project-card__cover">
              <Image src={entry.data.cover} alt={entry.data.title} />
            </div>
          )}
          <div class="project-card__body">
            <p class="project-card__status">
              <FileTerminal class="icon" size={15} aria-hidden="true" />
              case file
            </p>
            <h2 class="project-card__title">
              <a href={`/projects/${entry.slug}/`}>{entry.data.title}</a>
            </h2>
            <p class="project-card__date">
              <Calendar class="icon" size={14} aria-hidden="true" />
              {formatDate(entry.data.date)}
            </p>
            <p class="project-card__desc">{entry.data.description}</p>
            <ul class="project-card__tech">
              {entry.data.tech.map((tech) => (
                <li>
                  <Tags class="icon" size={13} aria-hidden="true" />
                  {tech}
                </li>
              ))}
            </ul>
            <p class="project-card__links">
              {entry.data.repoUrl && (
                <a href={entry.data.repoUrl} target="_blank" rel="noopener">
                  Repo <ExternalLink class="icon" size={14} aria-hidden="true" />
                </a>
              )}
              {entry.data.liveUrl && (
                <a href={entry.data.liveUrl} target="_blank" rel="noopener">
                  Live <ExternalLink class="icon" size={14} aria-hidden="true" />
                </a>
              )}
              <a href={`/projects/${entry.slug}/`}>
                Read more <ArrowRight class="icon" size={14} aria-hidden="true" />
              </a>
            </p>
          </div>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>

<style>
  .projects__header {
    padding: 20px 0 24px;
    border-bottom: 1px solid var(--line);
    margin-bottom: 24px;
  }

  .eyebrow {
    color: var(--magenta);
    font-size: 0.85rem;
    margin-bottom: 4px;
  }

  .projects__header h1 {
    font-size: 2rem;
    color: var(--text-strong);
    margin-bottom: 4px;
  }

  .projects__list {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 16px;
  }

  .project-card {
    background:
      linear-gradient(90deg, rgba(255, 79, 216, 0.08), transparent 44%),
      var(--panel);
    border: 1px solid var(--line);
    padding: 18px;
    position: relative;
  }

  .project-card:hover {
    border-color: var(--cyan);
    background-color: var(--panel-strong);
  }

  .project-card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 18px;
    bottom: 18px;
    width: 2px;
    background-color: var(--magenta);
  }

  .project-card__cover {
    margin-bottom: 12px;
  }

  .project-card__cover :global(img) {
    max-width: 100%;
    height: auto;
    display: block;
    border: 1px solid var(--line);
  }

  .project-card__status {
    color: var(--muted);
    font-size: 0.78rem;
    margin-bottom: 4px;
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .project-card__title {
    font-size: 1.25rem;
    margin-bottom: 4px;
  }

  .project-card__title a {
    color: var(--green);
  }

  .project-card__title a:hover,
  .project-card__title a:focus-visible {
    color: var(--cyan);
  }

  .project-card__date {
    font-size: 0.8rem;
    color: var(--muted);
    margin-bottom: 8px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .project-card__desc {
    margin-bottom: 10px;
  }

  .project-card__tech {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    padding: 0;
    margin-bottom: 10px;
  }

  .project-card__tech li {
    background-color: rgba(5, 7, 6, 0.7);
    border: 1px solid var(--line);
    padding: 3px 8px;
    font-size: 0.8rem;
    color: var(--text-strong);
    border-radius: 3px;
    display: inline-flex;
    align-items: center;
    gap: 5px;
  }

  .project-card__links {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    font-size: 0.92rem;
  }

  .project-card__links a {
    display: inline-flex;
    align-items: center;
    gap: 5px;
  }
</style>
