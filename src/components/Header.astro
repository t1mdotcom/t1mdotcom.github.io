---
import { siteConfig } from '../config';
import { Briefcase, Mail, Terminal, UserRound } from '@lucide/astro';

const currentPath = Astro.url.pathname.replace(/\/+$/, '') || '/';

const navItems = [
  { label: 'About', href: '/about', icon: UserRound },
  { label: 'Work', href: '/projects', icon: Briefcase },
  { label: 'Contact', href: '/contact', icon: Mail },
];

const isActive = (href: string) => {
  if (href === '/') return currentPath === '/';
  return currentPath === href || currentPath.startsWith(`${href}/`);
};
---

<header class="site-header">
  <div class="site-header__inner">
    <a class="site-header__brand" href="/">
      <span class="site-header__prompt"><Terminal class="icon" size={16} aria-hidden="true" /> ~/</span>
      <h1>{siteConfig.siteName}</h1>
    </a>
    <nav aria-label="Primary">
      <ul class="site-header__nav">
        {navItems.map(({ label, href, icon: Icon }) => (
          <li>
            <a
              href={href}
              aria-current={isActive(href) ? 'page' : undefined}
              class:list={['site-header__link', { 'is-active': isActive(href) }]}
            >
              <Icon class="icon" size={16} aria-hidden="true" />
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    background-color: rgba(5, 7, 6, 0.92);
    padding: 14px 20px;
    border-bottom: 1px solid var(--line);
  }

  .site-header__inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    max-width: 1100px;
    margin: 0 auto;
  }

  .site-header__brand {
    text-decoration: none;
    color: var(--text-strong);
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
  }

  .site-header__brand h1 {
    font-size: 1.4rem;
    font-weight: 400;
    margin: 0;
  }

  .site-header__prompt {
    color: var(--green);
    font-size: 0.95rem;
    display: inline-flex;
    align-items: center;
    gap: 5px;
  }

  .site-header__nav {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    margin: 0;
    padding: 0;
  }

  .site-header__link {
    color: var(--text);
    font-size: 1rem;
    border-bottom: 1px solid transparent;
    padding-bottom: 2px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .site-header__link:hover,
  .site-header__link:focus-visible {
    color: var(--cyan);
  }

  .site-header__link.is-active {
    color: var(--green);
    border-bottom-color: var(--magenta);
    text-decoration: none;
  }

  @media (max-width: 640px) {
    .site-header__inner {
      flex-direction: column;
      align-items: flex-start;
    }

    .site-header__nav {
      width: 100%;
      gap: 14px;
    }
  }
</style>
