---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config';
import { getPublishedProjects } from '../lib/projects';
import { Content as AboutContent, frontmatter as aboutFrontmatter } from '../content/about.md';
import { Image } from 'astro:assets';
import {
  Bot,
  Calendar,
  Code,
  ContactRound,
  Container,
  ExternalLink,
  FileTerminal,
  GitBranch,
  KeyRound,
  Mail,
  MapPin,
  Network,
  Send,
  ServerCog,
  Tags,
  Terminal,
  UserRound,
} from '@lucide/astro';

const projects = await getPublishedProjects();
const renderedProjects = await Promise.all(
  projects.map(async (entry) => ({
    entry,
    Content: (await entry.render()).Content,
  })),
);

const signals = [
  { label: 'Angular + TypeScript interfaces', icon: Code },
  { label: 'Java/Spring services with Gradle', icon: ServerCog },
  { label: 'GitLab/GitHub CI/CD and Docker', icon: Container },
  { label: 'Claude Code, Codex, Junie, CLI workflows', icon: Bot },
];

const gpgLink = siteConfig.socialLinks.find((link) => link.platform === 'GPG');
const linkedInLink = siteConfig.socialLinks.find((link) => link.platform === 'LinkedIn');
const profileLinks = siteConfig.socialLinks.filter((link) =>
  ['GitHub', 'LinkedIn', 'Xing'].includes(link.platform),
);

const getProfileIcon = (platform: string) => {
  if (platform === 'GitHub') return GitBranch;
  if (platform === 'LinkedIn') return ContactRound;
  return Network;
};

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout
  title={`${siteConfig.siteName} — AI-Augmented Software Engineer`}
  description={siteConfig.description}
>
  <section id="top" class="hero">
    <div class="terminal-panel" aria-label="Profile terminal">
      <div class="terminal-panel__bar">
        <span></span>
        <span></span>
        <span></span>
        <p><Terminal class="icon" size={14} aria-hidden="true" /> profile.sh</p>
      </div>
      <div class="terminal-panel__body">
        <p class="terminal-line"><span>$</span> whoami</p>
        <h1>{siteConfig.author}</h1>
        <p class="hero__role">AI-Augmented Software Engineer</p>
        <p class="terminal-line"><span>$</span> cat daily-focus.txt</p>
        <p class="hero__intro">
          Full-stack web development, DevOps tasks, and Linux server administration,
          sharpened by practical AI workflows on the command line.
        </p>
        <ul class="hero__signals" aria-label="Engineering focus">
          {signals.map(({ label, icon: Icon }) => (
            <li>
              <Icon class="icon" size={17} aria-hidden="true" />
              {label}
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="hero__ctas" aria-label="Primary actions">
      <a class="cta" href={linkedInLink?.url} target="_blank" rel="noopener">
        <ContactRound class="icon" size={18} aria-hidden="true" />
        Connect on LinkedIn
      </a>
      <a class="cta cta--ghost" href="#work">
        <GitBranch class="icon" size={18} aria-hidden="true" />
        View work patterns
      </a>
    </div>
  </section>

  <section id="about" class="section-block" aria-labelledby="about-heading">
    <header class="block-header">
      <p class="eyebrow">/about</p>
      <h2 id="about-heading">
        <UserRound class="icon" size={24} aria-hidden="true" />
        {aboutFrontmatter.name}
      </h2>
      <p class="block-header__role">{aboutFrontmatter.role}</p>
      <p class="block-header__location">
        <MapPin class="icon" size={15} aria-hidden="true" />
        {aboutFrontmatter.location}
      </p>
    </header>
    <article class="about__body markdown-body">
      <AboutContent />
    </article>
  </section>

  <section id="work" class="section-block" aria-labelledby="work-heading">
    <header class="block-header block-header--plain">
      <p class="eyebrow">/work</p>
      <h2 id="work-heading">Work Patterns</h2>
      <p>Selected areas from my daily engineering work.</p>
    </header>

    {renderedProjects.length > 0 ? (
      <div class="work__list">
        {renderedProjects.map(({ entry, Content }) => (
          <article class="project" id={`work-${entry.slug}`}>
            <header class="project__header">
              <p class="project__eyebrow">
                <FileTerminal class="icon" size={15} aria-hidden="true" />
                /work/{entry.slug}
              </p>
              <p class="project__date">
                <Calendar class="icon" size={14} aria-hidden="true" />
                {formatDate(entry.data.date)}
              </p>
              <h3>{entry.data.title}</h3>
              <p class="project__desc">{entry.data.description}</p>
              <ul class="project__tech">
                {entry.data.tech.map((tech) => (
                  <li>
                    <Tags class="icon" size={13} aria-hidden="true" />
                    {tech}
                  </li>
                ))}
              </ul>
              <p class="project__links">
                {entry.data.repoUrl && (
                  <a href={entry.data.repoUrl} target="_blank" rel="noopener">
                    Repo <ExternalLink class="icon" size={14} aria-hidden="true" />
                  </a>
                )}
                {entry.data.liveUrl && (
                  <a href={entry.data.liveUrl} target="_blank" rel="noopener">
                    Live <ExternalLink class="icon" size={14} aria-hidden="true" />
                  </a>
                )}
              </p>
            </header>

            {entry.data.cover && (
              <div class="project__cover">
                <Image src={entry.data.cover} alt={entry.data.title} />
              </div>
            )}

            <div class="project__body markdown-body">
              <Content />
            </div>
          </article>
        ))}
      </div>
    ) : (
      <p class="work__empty">Case files in progress.</p>
    )}
  </section>

  <section id="contact" class="section-block" aria-labelledby="contact-heading">
    <header class="block-header block-header--magenta">
      <p class="eyebrow">/contact</p>
      <h2 id="contact-heading">Contact</h2>
      <p>I am happily employed, but always open to thoughtful professional contact.</p>
    </header>

    {linkedInLink && (
      <div class="contact__panel contact__panel--primary">
        <h3>
          <Send class="icon" size={19} aria-hidden="true" />
          Preferred
        </h3>
        <p class="contact__copy">
          The cleanest route for professional exchange, recruiter contact, and relevant opportunities.
        </p>
        <p>
          <a class="primary-link" href={linkedInLink.url} target="_blank" rel="noopener">
            <ContactRound class="icon" size={18} aria-hidden="true" />
            Connect on LinkedIn
          </a>
        </p>
      </div>
    )}

    <div class="contact__panel">
      <h3>
        <Mail class="icon" size={19} aria-hidden="true" />
        E-mail
      </h3>
      <ul class="contact-info">
        <li>
          <a href={`mailto:${siteConfig.email}`}>
            <Mail class="icon" size={16} aria-hidden="true" />
            {siteConfig.email}
          </a>
        </li>
      </ul>
      {gpgLink && (
        <p>
          Public key:
          <a class="link" href={gpgLink.url} target="_blank" rel="noopener">
            <KeyRound class="icon" size={15} aria-hidden="true" />
            GPG on keyserver.ubuntu.com
            <ExternalLink class="icon" size={14} aria-hidden="true" />
          </a>
        </p>
      )}
    </div>

    <div class="contact__panel">
      <h3>
        <Network class="icon" size={19} aria-hidden="true" />
        Profiles
      </h3>
      <ul class="social-links">
        {profileLinks.map((link) => {
          const Icon = getProfileIcon(link.platform);
          return (
            <li>
              <a href={link.url} target="_blank" rel="noopener">
                <Icon class="icon" size={16} aria-hidden="true" />
                {link.platform}
                <ExternalLink class="icon" size={13} aria-hidden="true" />
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  /* ---- shared section scaffold ---- */
  .section-block {
    padding: 40px 0;
    border-top: 1px solid var(--line);
  }

  .block-header {
    padding: 20px;
    border: 1px solid var(--line);
    background:
      linear-gradient(90deg, rgba(97, 217, 255, 0.08), transparent 52%),
      var(--panel);
    margin-bottom: 24px;
  }

  .block-header--magenta {
    background:
      linear-gradient(90deg, rgba(255, 79, 216, 0.08), transparent 50%),
      var(--panel);
  }

  .block-header--plain {
    padding: 0 0 18px;
    border: none;
    background: none;
    border-bottom: 1px solid var(--line);
  }

  .eyebrow {
    color: var(--magenta);
    font-size: 0.85rem;
    margin-bottom: 4px;
  }

  .block-header h2 {
    font-size: 2rem;
    color: var(--text-strong);
    margin-bottom: 4px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .block-header__role {
    color: var(--green);
    margin-bottom: 4px;
  }

  .block-header__location {
    font-size: 0.9rem;
    color: var(--muted);
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  /* ---- hero ---- */
  .hero {
    padding: 22px 0 34px;
  }

  .terminal-panel {
    background:
      linear-gradient(135deg, rgba(121, 255, 180, 0.08), transparent 34%),
      var(--panel);
    border: 1px solid var(--line-strong);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.04),
      0 18px 50px rgba(0, 0, 0, 0.35);
  }

  .terminal-panel__bar {
    min-height: 40px;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 0 14px;
    background-color: rgba(5, 7, 6, 0.86);
    border-bottom: 1px solid var(--line);
  }

  .terminal-panel__bar span {
    width: 9px;
    height: 9px;
    border-radius: 999px;
    border: 1px solid var(--line-strong);
  }

  .terminal-panel__bar span:nth-child(1) {
    background-color: var(--magenta);
  }

  .terminal-panel__bar span:nth-child(2) {
    background-color: var(--cyan);
  }

  .terminal-panel__bar span:nth-child(3) {
    background-color: var(--green);
  }

  .terminal-panel__bar p {
    margin-left: 8px;
    color: var(--muted);
    font-size: 0.82rem;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .terminal-panel__body {
    padding: 28px;
  }

  .terminal-line {
    color: var(--muted);
    font-size: 0.92rem;
    margin-bottom: 6px;
  }

  .terminal-line span {
    color: var(--green);
  }

  .hero h1 {
    font-size: 2.4rem;
    color: var(--text-strong);
    margin-bottom: 4px;
  }

  .hero__role {
    color: var(--green);
    margin-bottom: 22px;
    font-size: 1rem;
  }

  .hero__intro {
    max-width: 760px;
    margin-bottom: 18px;
    color: var(--text-strong);
  }

  .hero__signals {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 8px;
    padding: 0;
    margin-top: 18px;
  }

  .hero__signals li {
    background-color: rgba(5, 7, 6, 0.5);
    border: 1px solid var(--line);
    color: var(--text);
    padding: 9px 11px;
    font-size: 0.9rem;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .hero__signals :global(.icon) {
    color: var(--magenta);
  }

  .hero__ctas {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin-top: 22px;
  }

  .cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 11px 18px;
    border: 1px solid var(--line-strong);
    color: var(--bg-deep);
    background-color: var(--green);
    box-shadow: 0 0 22px rgba(121, 255, 180, 0.16);
  }

  .cta:hover,
  .cta:focus-visible {
    background-color: var(--cyan);
    border-color: var(--cyan);
    color: var(--bg-deep);
  }

  .cta--ghost {
    background-color: transparent;
    border-color: var(--line);
    color: var(--text);
    box-shadow: none;
  }

  .cta--ghost:hover,
  .cta--ghost:focus-visible {
    background-color: rgba(97, 217, 255, 0.08);
    border-color: var(--cyan);
    color: var(--cyan);
  }

  /* ---- about ---- */
  .about__body {
    max-width: 820px;
  }

  /* ---- work ---- */
  .work__list {
    display: grid;
    gap: 20px;
  }

  .project {
    background:
      linear-gradient(90deg, rgba(255, 79, 216, 0.08), transparent 44%),
      var(--panel);
    border: 1px solid var(--line);
    padding: 20px;
    position: relative;
  }

  .project::before {
    content: '';
    position: absolute;
    left: 0;
    top: 20px;
    bottom: 20px;
    width: 2px;
    background-color: var(--magenta);
  }

  .project__eyebrow {
    color: var(--magenta);
    font-size: 0.82rem;
    margin-bottom: 8px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .project__date {
    font-size: 0.85rem;
    color: var(--muted);
    margin-bottom: 6px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .project__header h3 {
    font-size: 1.5rem;
    color: var(--green);
    margin-bottom: 8px;
  }

  .project__desc {
    margin-bottom: 14px;
    color: var(--text);
  }

  .project__tech {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    padding: 0;
    margin-bottom: 14px;
  }

  .project__tech li {
    background-color: rgba(5, 7, 6, 0.7);
    border: 1px solid var(--line);
    padding: 3px 8px;
    font-size: 0.8rem;
    color: var(--text-strong);
    border-radius: 3px;
    display: inline-flex;
    align-items: center;
    gap: 5px;
  }

  .project__links {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    font-size: 0.92rem;
    margin-bottom: 4px;
  }

  .project__links a {
    display: inline-flex;
    align-items: center;
    gap: 5px;
  }

  .project__cover {
    margin: 16px 0;
  }

  .project__cover :global(img) {
    max-width: 100%;
    height: auto;
    display: block;
    border: 1px solid var(--line);
  }

  .project__body {
    border-top: 1px solid var(--line);
    margin-top: 16px;
    padding-top: 4px;
  }

  .work__empty {
    color: var(--muted);
  }

  /* ---- markdown ---- */
  .markdown-body :global(h1),
  .markdown-body :global(h2),
  .markdown-body :global(h3) {
    color: var(--text-strong);
    margin-top: 22px;
    margin-bottom: 10px;
  }

  .markdown-body :global(p) {
    margin-bottom: 12px;
    line-height: 1.7;
  }

  .markdown-body :global(ul),
  .markdown-body :global(ol) {
    margin-left: 20px;
    margin-bottom: 12px;
  }

  .markdown-body :global(a) {
    color: var(--green);
  }

  .markdown-body :global(a:hover) {
    color: var(--cyan);
  }

  .markdown-body :global(code) {
    background-color: var(--panel);
    padding: 2px 6px;
    border-radius: 3px;
  }

  .markdown-body :global(pre) {
    background-color: var(--panel);
    padding: 12px 14px;
    border-radius: 4px;
    overflow-x: auto;
  }

  /* ---- contact ---- */
  .contact__panel {
    margin-bottom: 24px;
  }

  .contact__panel--primary {
    padding: 18px;
    background-color: var(--panel);
    border: 1px solid var(--line-strong);
  }

  .contact__copy {
    max-width: 620px;
    margin-bottom: 14px;
  }

  .contact__panel h3 {
    font-size: 1.2rem;
    color: var(--text-strong);
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .contact-info,
  .social-links {
    list-style: none;
    padding: 0;
  }

  .contact-info li {
    margin-bottom: 8px;
  }

  .social-links {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
  }

  .link {
    margin-left: 4px;
    display: inline-flex;
    align-items: center;
    gap: 5px;
  }

  .contact-info a,
  .social-links a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .primary-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
    border: 1px solid var(--line-strong);
    background-color: var(--green);
    color: var(--bg-deep);
  }

  .primary-link:hover,
  .primary-link:focus-visible {
    background-color: var(--cyan);
    border-color: var(--cyan);
    color: var(--bg-deep);
  }

  @media (max-width: 760px) {
    .terminal-panel__body {
      padding: 20px;
    }

    .hero h1 {
      font-size: 2rem;
    }

    .hero__signals {
      grid-template-columns: 1fr;
    }
  }
</style>
